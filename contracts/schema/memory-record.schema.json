{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory-record.schema.json",
  "title": "MemoryRecord",
  "description": "Knowledge with provenance, projected from journal events. final.md §7.7, §12.6, §13.4.",
  "type": "object",
  "additionalProperties": false,
  "required": ["memory_id", "source_event_id", "source_digest", "writer", "created_at", "kind", "content_ref", "summary", "confidence_basis_points", "sensitivity", "access_policy"],
  "properties": {
    "memory_id": { "type": "string", "minLength": 1 },
    "source_event_id": { "type": "string", "minLength": 1 },
    "source_digest": { "type": "string" },
    "writer": { "type": "string" },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "kind": { "type": "string" },
    "content_ref": { "type": "string" },
    "summary": { "type": "string" },
    "confidence_basis_points": { "type": "integer", "minimum": 0, "maximum": 65535 },
    "sensitivity": { "$ref": "common.schema.json#/$defs/data_class" },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "access_policy": { "type": "string" }
  }
}
