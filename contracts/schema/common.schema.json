{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "beaterOS shared contract vocabulary",
  "description": "Enums and shared structures for the core contracts. Schema names and snake_case enum values mirror the Rust wire format in crates/beater-os-core.",
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 / ISO 8601 UTC timestamp."
    },
    "uint": { "type": "integer", "minimum": 0 },
    "action_kind": {
      "type": "string",
      "enum": ["read", "write", "execute", "navigate", "submit", "communicate", "spend", "deploy", "remember", "delegate", "ask_human"]
    },
    "resource_kind": {
      "type": "string",
      "enum": ["workspace", "file_path", "network_endpoint", "browser_origin", "tool", "memory", "model_route", "payment_rail", "cloud_resource", "human_recipient", "scenario", "other"]
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "data_class": {
      "type": "string",
      "enum": ["public", "internal", "personal", "customer", "financial", "secret", "code", "binary", "untrusted_web", "untrusted_email", "untrusted_document", "tool_output"]
    },
    "side_effect_class": {
      "type": "string",
      "enum": ["none", "local_write", "network_write", "browser_submit", "human_communication", "payment", "cloud_mutation", "deployment", "memory_write", "delegation"]
    },
    "taint_label": {
      "type": "string",
      "enum": ["trusted_user_instruction", "system_policy", "developer_instruction", "untrusted_web", "untrusted_email", "untrusted_document", "tool_output", "secret", "personal_data", "customer_data", "financial_data", "code", "binary", "payment_instruction"]
    },
    "session_status": {
      "type": "string",
      "enum": ["created", "running", "waiting_for_approval", "paused", "completed", "failed", "canceled"]
    },
    "decision_result": {
      "type": "string",
      "enum": ["allowed", "denied", "needs_approval", "needs_simulation", "needs_narrowed_grant"]
    },
    "hash_value": {
      "description": "Lowercase hex SHA-256 digest. GENESIS_HASH is 64 zeros (hash.rs).",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "delegation_mode": {
      "type": "string",
      "enum": ["none", "attenuated_only", "same_scope"]
    },
    "approval_mode": {
      "type": "string",
      "enum": ["none", "human", "multi_party"]
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional resource ceilings. Absent field = unbounded on the limit side, but fails closed when a grant sets a ceiling the action does not request.",
      "properties": {
        "max_model_cents": { "$ref": "#/$defs/uint" },
        "max_tool_calls": { "$ref": "#/$defs/uint" },
        "max_wall_ms": { "$ref": "#/$defs/uint" },
        "max_payment_minor_units": { "$ref": "#/$defs/uint" }
      }
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_routes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "local_only": { "type": "boolean" },
        "max_data_class": { "$ref": "#/$defs/data_class" }
      }
    },
    "capability_selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_kind", "resource_id"],
      "properties": {
        "resource_kind": { "$ref": "#/$defs/resource_kind" },
        "resource_id": { "type": "string", "description": "Concrete id, or \"*\" wildcard within the resource kind." }
      }
    },
    "capability_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "actions"],
      "properties": {
        "selector": { "$ref": "#/$defs/capability_selector" },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action_kind" }, "uniqueItems": true }
      }
    },
    "execution_lease": {
      "type": "object",
      "additionalProperties": false,
      "description": "Daemon-issued single-use authority to execute one previously Allowed action. The lease is journaled and synced before side effects begin.",
      "required": ["lease_id", "session_id", "action_id", "manifest_hash", "decision_id", "tool_id", "tool_ref", "target", "leased_at", "expires_at"],
      "properties": {
        "lease_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "minLength": 1 },
        "manifest_hash": { "$ref": "#/$defs/hash_value" },
        "decision_id": { "type": "string", "minLength": 1 },
        "tool_id": { "type": "string", "minLength": 1 },
        "tool_ref": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/$defs/capability_selector" },
        "required_grants": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "requested_budget": { "$ref": "#/$defs/budget" },
        "leased_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "execution_lease_resolution": {
      "type": "string",
      "enum": ["outcome_unknown"]
    },
    "execution_lease_heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "description": "Daemon-recorded liveness renewal for an open execution lease. It can extend only a still-live lease and cannot create a receipt, reconciliation, or new authority.",
      "required": ["heartbeat_id", "lease_id", "session_id", "action_id", "manifest_hash", "decision_id", "previous_expires_at", "extended_expires_at", "observed_by", "heartbeat_at"],
      "properties": {
        "heartbeat_id": { "type": "string", "minLength": 1 },
        "lease_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "minLength": 1 },
        "manifest_hash": { "$ref": "#/$defs/hash_value" },
        "decision_id": { "type": "string", "minLength": 1 },
        "previous_expires_at": { "$ref": "#/$defs/timestamp" },
        "extended_expires_at": { "$ref": "#/$defs/timestamp" },
        "observed_by": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "heartbeat_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "execution_lease_reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Operator reconciliation for an expired unresolved execution lease. This closes a recovery blocker without creating a receipt or proving success.",
      "required": ["reconciliation_id", "lease_id", "session_id", "action_id", "manifest_hash", "decision_id", "resolution", "reconciled_by", "reason", "reconciled_at"],
      "properties": {
        "reconciliation_id": { "type": "string", "minLength": 1 },
        "lease_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "minLength": 1 },
        "manifest_hash": { "$ref": "#/$defs/hash_value" },
        "decision_id": { "type": "string", "minLength": 1 },
        "resolution": { "$ref": "#/$defs/execution_lease_resolution" },
        "reconciled_by": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "reconciled_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "grant_constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_risk": { "$ref": "#/$defs/risk_class" },
        "max_data_class": { "$ref": "#/$defs/data_class" },
        "budget": { "$ref": "#/$defs/budget" },
        "network_allowlist": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "path_prefixes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "approval_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "threshold_risk"],
      "properties": {
        "mode": { "$ref": "#/$defs/approval_mode" },
        "threshold_risk": { "$ref": "#/$defs/risk_class" },
        "reviewer_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "approval_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "action_id", "manifest_hash", "grant_id", "reviewer_id", "approved_at", "policy_version"],
      "properties": {
        "review_id": { "type": "string" },
        "action_id": { "type": "string" },
        "manifest_hash": { "$ref": "#/$defs/hash_value" },
        "grant_id": { "type": "string" },
        "reviewer_id": { "type": "string" },
        "approved_at": { "$ref": "#/$defs/timestamp" },
        "policy_version": { "type": "string" }
      }
    },
    "simulation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["simulation_id", "action_id", "manifest_hash", "scenario_id", "passed_at", "policy_version"],
      "properties": {
        "simulation_id": { "type": "string" },
        "action_id": { "type": "string" },
        "manifest_hash": { "$ref": "#/$defs/hash_value" },
        "scenario_id": { "type": "string" },
        "passed_at": { "$ref": "#/$defs/timestamp" },
        "policy_version": { "type": "string" }
      }
    }
  }
}
