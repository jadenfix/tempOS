{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "action-manifest.schema.json",
  "title": "ActionManifest",
  "description": "A predeclared proposed side effect or observation, admitted by policy before execution. final.md §7.4, §12.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_id", "session_id", "tool_id", "action_kind", "target", "inputs_digest", "inputs_summary", "risk_class", "human_explanation"],
  "properties": {
    "action_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string" },
    "tool_id": { "type": "string" },
    "action_kind": { "$ref": "common.schema.json#/$defs/action_kind" },
    "target": { "$ref": "common.schema.json#/$defs/capability_selector" },
    "resolved_target": { "$ref": "common.schema.json#/$defs/capability_selector" },
    "inputs_digest": { "type": "string" },
    "inputs_summary": { "type": "string" },
    "expected_outputs": { "type": "array", "items": { "type": "string" } },
    "expected_side_effects": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/side_effect_class" }, "uniqueItems": true },
    "required_grants": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "requested_budget": { "$ref": "common.schema.json#/$defs/budget" },
    "risk_class": { "$ref": "common.schema.json#/$defs/risk_class" },
    "data_classes": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/data_class" }, "uniqueItems": true },
    "taint": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/taint_label" }, "uniqueItems": true },
    "idempotency_key": { "type": "string" },
    "payment_intent": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mandate_id", "rail", "adapter_id", "asset", "amount_minor_units", "counterparty_ref", "counterparty_binding_hash", "purpose", "payment_idempotency_key", "envelope_format", "envelope_hash"],
          "properties": {
            "mandate_id": { "type": "string", "minLength": 1 },
            "rail": { "type": "string", "minLength": 1 },
            "adapter_id": { "type": "string", "minLength": 1 },
            "adapter_version": { "type": ["string", "null"], "minLength": 1 },
            "asset": { "type": "string", "minLength": 1 },
            "amount_minor_units": { "type": "integer", "minimum": 1 },
            "counterparty_ref": { "type": "string", "minLength": 1 },
            "counterparty_binding_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "purpose": { "type": "string", "minLength": 1 },
            "payment_idempotency_key": { "type": "string", "minLength": 1 },
            "envelope_format": { "type": "string", "minLength": 1 },
            "envelope_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "envelope_expires_at": { "oneOf": [{ "$ref": "common.schema.json#/$defs/timestamp" }, { "type": "null" }] }
          }
        },
        { "type": "null" }
      ]
    },
    "compensation_plan": { "type": "string" },
    "human_explanation": { "type": "string" }
  }
}
