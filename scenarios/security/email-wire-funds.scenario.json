          "holder": "agent:inbox-1",
          "session_id": "sess-inbox",
          "scope": { "selector": { "resource_kind": "payment_rail", "resource_id": "bank-wire" }, "actions": ["spend"] },
          "constraints": { "max_risk": "critical", "max_data_class": "financial", "budget": { "max_payment_minor_units": 100000000 } },
          "expires_at": "2026-07-03T21:00:00Z",
          "delegation": "none",
          "revocation_handle": "rev:grant-wire",
          "policy_version": "policy-2026-07-03.dev",
          "reason": "Settle approved vendor invoices."
